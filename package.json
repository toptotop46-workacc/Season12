{
  "name": "soneium-automation",
  "version": "12.0.0",
  "description": "Автоматизация операций в сети Soneium с случайным выбором модулей и ключей",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "postinstall": "npm run build",
    "arkada-checkin": "tsx src/run-module.ts arkada-checkin",
    "jumper": "tsx src/run-module.ts jumper",
    "lootcoin": "tsx src/run-module.ts lootcoin",
    "revoke": "tsx src/run-module.ts revoke",
    "harkan": "tsx src/run-module.ts harkan",
    "velodrome": "tsx src/run-module.ts velodrome",
    "wowmax": "tsx src/run-module.ts wowmax",
    "captain-checkin": "tsx src/run-module.ts captain-checkin",
    "startale-gm": "tsx src/run-module.ts startale-gm",
    "startale-swap": "tsx src/run-module.ts startale-swap",
    "startale-invite": "tsx src/run-module.ts startale-invite",
    "fantasyteam-mint": "tsx src/run-module.ts fantasyteam-mint",
    "sweep-mint": "tsx src/run-module.ts sweep-mint",
    "onchaingm": "tsx src/run-module.ts onchaingm",
    "hecanos-mint": "tsx src/run-module.ts hecanos-mint"
  },
  "keywords": [
    "soneium",
    "blockchain",
    "automation",
    "defi",
    "typescript"
  ],
  "author": "Soneium Automation",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.5",
    "exceljs": "^4.4.0",
    "fast-deep-equal": "^3.1.3",
    "https-proxy-agent": "^7.0.6",
    "patchright": "^1.59.4",
    "prompts": "^2.4.2",
    "readline-sync": "^1.4.10",
    "socks-proxy-agent": "^8.0.5",
    "undici": "^7.25.0",
    "viem": "^2.39.3",
    "web3": "^4.16.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/prompts": "^2.4.9",
    "@types/readline-sync": "^1.4.8",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^9.39.1",
    "js-yaml": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "glob": "^13.0.6",
    "rimraf": "^6.1.0",
    "lodash.isequal": "npm:fast-deep-equal@^3.1.3",
    "unzipper": "^0.12.3",
    "@isaacs/brace-expansion": "^5.0.1",
    "uuid": "^11.0.0",
    "esbuild": "^0.28.1",
    "form-data": "^4.0.6",
    "js-yaml": "^4.2.0",
    "ws": "^8.21.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
