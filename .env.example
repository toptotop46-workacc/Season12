# Soneium Automation — Environment Configuration
# Copy this file to .env and customise as needed.
# All values have sensible defaults; you only need to override what you want.

# RPC endpoints (comma-separated, first = primary, rest = fallbacks)
# SONEIUM_RPC_URLS=https://soneium-rpc.publicnode.com,https://1868.rpc.thirdweb.com,https://soneium.drpc.org,https://soneium.rpc.hypersync.xyz

# RPC call timeout (ms)
# RPC_TIMEOUT_MS=10000

# RPC retry count per node
# RPC_RETRY_COUNT=3

# RPC retry delay (ms)
# RPC_RETRY_DELAY_MS=1000

# Stats API base URL
# STATS_API_BASE_URL=https://portal.soneium.org/api

# Stats API request timeout (ms)
# STATS_API_TIMEOUT_MS=10000

# Stats API retry attempts
# STATS_API_RETRY_ATTEMPTS=10

# Block explorer URL
# EXPLORER_URL=https://soneium.blockscout.com
